# Archery Duels — copy to `.env` and fill in real values. Never commit `.env`.

# Open Cloud API key with DataStore read scope on the ARCHERY DUELS universe.
# NOTE: the ocean-quest key will NOT work here — its access list only contains
# the ocean-quest universe. Either extend that key to include Archery Duels in
# the Creator Dashboard, or generate a new key scoped to this universe.
ROBLOX_API_KEY=your-archery-duels-open-cloud-api-key

# The Archery Duels universe id (NOT ocean-quest's 9995597543).
ROBLOX_UNIVERSE_ID=

# Daemon writes via this URL once the full dumper exists (read+write role,
# localhost — no SSL needed). On the box:
#   postgresql://archery_duels_rw:STRONG_PASSWORD@localhost/archery_duels
DATABASE_URL=postgresql://archery_duels_rw:CHANGE_ME@localhost/archery_duels
